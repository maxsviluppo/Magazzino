rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(warehouseId) {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/warehouses/$(warehouseId)).data.ownerUid == request.auth.uid
      );
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "castromassimo@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function hasOnlyAllowedFields(data, fields) {
      return data.keys().hasOnly(fields);
    }

    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidWarehouse(data) {
      return hasOnlyAllowedFields(data, ['name', 'ownerUid', 'createdAt']) &&
             isValidString(data.name, 1, 100) &&
             data.ownerUid == request.auth.uid;
    }

    function isValidTransaction(data) {
      return hasOnlyAllowedFields(data, ['warehouseId', 'type', 'date', 'description', 'quantity', 'unitCost', 'totalCost', 'createdAt']) &&
             data.type in ['in', 'out'] &&
             isValidString(data.description, 1, 200) &&
             data.quantity is number && data.quantity != 0 &&
             data.unitCost is number && data.unitCost >= 0 &&
             data.totalCost is number;
    }

    function isValidInventoryItem(data) {
      return hasOnlyAllowedFields(data, ['warehouseId', 'description', 'quantity', 'unitCost', 'totalValue', 'lastUpdated']) &&
             isValidString(data.description, 1, 200) &&
             data.quantity is number &&
             data.unitCost is number &&
             data.totalValue is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /warehouses/{warehouseId} {
      allow read: if isAuthenticated() && (resource.data.ownerUid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidWarehouse(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.ownerUid == request.auth.uid || isAdmin()) && isValidWarehouse(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.ownerUid == request.auth.uid || isAdmin());

      match /transactions/{transactionId} {
        allow read: if isOwner(warehouseId) || isAdmin();
        allow create: if isOwner(warehouseId) && isValidTransaction(request.resource.data);
        allow update: if isOwner(warehouseId) && isValidTransaction(request.resource.data);
        allow delete: if isOwner(warehouseId) || isAdmin();
      }

      match /inventory/{inventoryItemId} {
        allow read: if isOwner(warehouseId) || isAdmin();
        allow create: if isOwner(warehouseId) && isValidInventoryItem(request.resource.data);
        allow update: if isOwner(warehouseId) && isValidInventoryItem(request.resource.data);
        allow delete: if isOwner(warehouseId) || isAdmin();
      }
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
